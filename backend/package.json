{
  "name": "backend",
  "version": "1.0.0",
  "description": "This directory contains the backend API server for CaddyManager, providing the core functionality for managing Caddy Server configurations, user authentication, and proxy management.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:watch": "jest --watch",
    "audit:check": "npm audit --audit-level=high",
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:cluster": "CLUSTER_MODE=true node src/cluster.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "axios": "^1.12.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dockerode": "^4.0.2",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.2",
    "otplib": "^13.3.0",
    "pg": "^8.16.0",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.7",
    "simple-git": "^3.25.0",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.3",
    "supertest": "^7.1.4"
  }
}
